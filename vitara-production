<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Welcome to Vitara ✦</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#06080F;--gold:#C9A84C;--green:#4CAF7D;
  --text:#F0EDE6;--muted:#6B7280;--surface:#0D1117;--border:rgba(255,255,255,0.07);
}
body{
  background:var(--bg);font-family:'Outfit',sans-serif;
  color:var(--text);min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
}

/* Particle canvas */
#canvas{position:fixed;inset:0;pointer-events:none;z-index:0}

.card{
  position:relative;z-index:1;
  background:var(--surface);border:1px solid var(--border);
  border-radius:32px;padding:64px 56px;
  max-width:520px;width:100%;text-align:center;
  box-shadow:0 40px 120px rgba(0,0,0,0.5);
  animation:rise .8s cubic-bezier(.16,1,.3,1) both;
}
@keyframes rise{from{opacity:0;transform:translateY(40px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}

/* Loading state */
.state-loading{display:flex;flex-direction:column;align-items:center;gap:20px}
.loader-ring{
  width:64px;height:64px;border-radius:50%;
  border:3px solid var(--border);
  border-top-color:var(--gold);
  animation:spin .9s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:15px;color:var(--muted);font-weight:300}

/* Success state */
.state-success{display:none;flex-direction:column;align-items:center}
.checkmark-wrap{
  width:80px;height:80px;border-radius:50%;
  background:rgba(76,175,125,0.12);border:1px solid rgba(76,175,125,0.3);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:28px;
  animation:popIn .5s cubic-bezier(.16,1,.3,1) .3s both;
}
@keyframes popIn{from{transform:scale(0)}to{transform:scale(1)}}
.checkmark{font-size:36px}

.welcome-label{
  font-size:11px;letter-spacing:4px;text-transform:uppercase;
  color:var(--gold);font-weight:700;margin-bottom:12px;
}
h1{
  font-family:'Cormorant Garamond',serif;
  font-size:42px;font-weight:600;line-height:1.1;
  margin-bottom:12px;letter-spacing:-0.5px;
}
h1 em{font-style:italic;color:var(--gold)}
.subtitle{font-size:16px;color:var(--muted);line-height:1.7;font-weight:300;margin-bottom:36px}

/* Plan badge */
.plan-badge{
  display:inline-flex;align-items:center;gap:10px;
  background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.25);
  border-radius:50px;padding:10px 20px;margin-bottom:36px;
}
.plan-icon{font-size:20px}
.plan-info{text-align:left}
.plan-name{font-size:14px;font-weight:600;color:var(--text)}
.plan-detail{font-size:12px;color:var(--gold)}

/* Details row */
.details-row{
  display:flex;gap:16px;margin-bottom:36px;width:100%;
}
.detail-box{
  flex:1;background:rgba(255,255,255,0.03);border:1px solid var(--border);
  border-radius:16px;padding:16px;text-align:center;
}
.detail-val{
  font-family:'Cormorant Garamond',serif;
  font-size:20px;font-weight:600;color:var(--text);margin-bottom:4px;
}
.detail-lbl{font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase}

/* Steps */
.next-steps{
  background:rgba(255,255,255,0.02);border:1px solid var(--border);
  border-radius:20px;padding:24px;text-align:left;width:100%;margin-bottom:32px;
}
.steps-title{font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:16px}
.step-row{display:flex;align-items:center;gap:14px;padding:10px 0;border-bottom:1px solid var(--border)}
.step-row:last-child{border-bottom:none}
.step-num{
  width:28px;height:28px;border-radius:50%;
  background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:700;color:var(--gold);flex-shrink:0;
}
.step-text{font-size:14px;color:var(--muted);font-weight:300}
.step-text strong{color:var(--text);font-weight:500}

.btn-start{
  width:100%;padding:18px;border-radius:50px;
  background:linear-gradient(135deg,var(--gold),#A8752A);
  color:#06080F;font-size:15px;font-weight:700;letter-spacing:.5px;
  border:none;cursor:pointer;font-family:'Outfit',sans-serif;
  transition:all .25s;display:flex;align-items:center;justify-content:center;gap:10px;
}
.btn-start:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(201,168,76,0.3)}
.btn-start .arrow{transition:transform .2s}
.btn-start:hover .arrow{transform:translateX(4px)}

.receipt-note{
  margin-top:20px;font-size:12px;color:var(--muted);
  display:flex;align-items:center;gap:6px;justify-content:center;
}

/* Error state */
.state-error{display:none;flex-direction:column;align-items:center;text-align:center}
.error-icon{font-size:48px;margin-bottom:20px}
.error-title{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:600;margin-bottom:12px}
.error-msg{font-size:15px;color:var(--muted);margin-bottom:28px;line-height:1.6}
.btn-retry{
  padding:14px 32px;border-radius:50px;border:1px solid var(--border);
  color:var(--text);background:transparent;font-size:14px;font-weight:500;
  cursor:pointer;font-family:'Outfit',sans-serif;transition:all .2s;
}
.btn-retry:hover{border-color:var(--gold);color:var(--gold)}
</style>
</head>
<body>
<canvas id="canvas"></canvas>

<div class="card" id="card">
  <!-- LOADING -->
  <div class="state-loading" id="stateLoading">
    <div class="loader-ring"></div>
    <div class="loading-text">Confirming your payment...</div>
  </div>

  <!-- SUCCESS -->
  <div class="state-success" id="stateSuccess">
    <div class="checkmark-wrap"><div class="checkmark">✓</div></div>
    <div class="welcome-label">Payment Confirmed</div>
    <h1>Welcome to<br/><em>Vitara.</em></h1>
    <p class="subtitle">Your wellness journey starts right now. Let's set up your first personalized plan.</p>

    <div class="plan-badge">
      <div class="plan-icon" id="planIcon">✦</div>
      <div class="plan-info">
        <div class="plan-name" id="planName">Vitara Pro</div>
        <div class="plan-detail" id="planDetail">7-day free trial active</div>
      </div>
    </div>

    <div class="details-row">
      <div class="detail-box">
        <div class="detail-val" id="detailEmail">—</div>
        <div class="detail-lbl">Account</div>
      </div>
      <div class="detail-box">
        <div class="detail-val" id="detailTrialEnd">—</div>
        <div class="detail-lbl">Trial Ends</div>
      </div>
    </div>

    <div class="next-steps">
      <div class="steps-title">What happens next</div>
      <div class="step-row">
        <div class="step-num">1</div>
        <div class="step-text"><strong>Set your goals</strong> — tell us what you want to achieve</div>
      </div>
      <div class="step-row">
        <div class="step-num">2</div>
        <div class="step-text"><strong>Your first check-in</strong> — rate how you're feeling today</div>
      </div>
      <div class="step-row">
        <div class="step-num">3</div>
        <div class="step-text"><strong>AI builds your plan</strong> — personalized in seconds</div>
      </div>
    </div>

    <button class="btn-start" onclick="goToOnboarding()">
      Start My Onboarding <span class="arrow">→</span>
    </button>
    <div class="receipt-note">📧 A receipt has been sent to your email via Stripe</div>
  </div>

  <!-- ERROR -->
  <div class="state-error" id="stateError">
    <div class="error-icon">⚠️</div>
    <div class="error-title">Something went wrong</div>
    <p class="error-msg" id="errorMsg">We couldn't confirm your payment. Please contact support or try again.</p>
    <button class="btn-retry" onclick="window.location.href='vitara-global.html'">← Back to Vitara</button>
  </div>
</div>

<script>
// ── PARTICLES ──
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
const particles = Array.from({length:60},()=>({
  x:Math.random()*canvas.width, y:Math.random()*canvas.height,
  vx:(Math.random()-.5)*.3, vy:(Math.random()-.5)*.3,
  r:Math.random()*2+.5,
  alpha:Math.random()*.4+.05,
  color:Math.random()>.5?'201,168,76':'76,175,125'
}));
function animParticles(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  particles.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy;
    if(p.x<0||p.x>canvas.width) p.vx*=-1;
    if(p.y<0||p.y>canvas.height) p.vy*=-1;
    ctx.beginPath();
    ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(${p.color},${p.alpha})`;
    ctx.fill();
  });
  requestAnimationFrame(animParticles);
}
animParticles();
window.addEventListener('resize',()=>{ canvas.width=window.innerWidth; canvas.height=window.innerHeight; });

// ── CONFIRM PAYMENT ──
// 🔧 CONFIGURACIÓN: cambia esta URL por la de tu servidor en Railway
// Ejemplo: "https://vitara-production.up.railway.app"
const SERVER = window.location.hostname === "localhost"
  ? "http://localhost:4242"
  : "https://TU-SERVIDOR.up.railway.app";

async function confirmSession() {
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get("session_id");
  const plan = params.get("plan"); // for free plan redirect

  // Free plan — no Stripe session
  if (plan === "free" || !sessionId) {
    showSuccess({
      customer_email: "—",
      plan: "free",
      trial_end: null,
    });
    return;
  }

  try {
    const res = await fetch(`${SERVER}/session-status?session_id=${sessionId}`);
    const data = await res.json();

    if (data.error) throw new Error(data.error);
    if (data.status !== "complete" && data.payment_status !== "paid" && data.payment_status !== "no_payment_required") {
      throw new Error("Payment not confirmed yet. Please wait a moment and refresh.");
    }

    showSuccess(data);

    // Store session info locally for dashboard
    localStorage.setItem("vitara_user", JSON.stringify({
      email: data.customer_email,
      name: data.customer_name,
      plan: data.plan || "pro",
      subscription_id: data.subscription_id,
      trial_end: data.trial_end,
      joined: new Date().toISOString(),
    }));

  } catch (err) {
    // If server is not running (demo mode), show success anyway
    if (err.message.includes("fetch") || err.message.includes("Failed")) {
      showSuccess({ customer_email: "demo@vitara.app", plan: "pro", trial_end: Date.now()/1000 + 7*86400 });
    } else {
      showError(err.message);
    }
  }
}

function showSuccess(data) {
  document.getElementById('stateLoading').style.display = 'none';
  document.getElementById('stateSuccess').style.display = 'flex';

  const planData = {
    free:   { icon:'🌱', name:'Vitara Free',   detail:'Always free · No limits on check-ins' },
    pro:    { icon:'✦',  name:'Vitara Pro',    detail:'7-day free trial active' },
    annual: { icon:'🌍', name:'Vitara Annual', detail:'Best value · Full access unlocked' },
  };
  const p = planData[data.plan] || planData.pro;
  document.getElementById('planIcon').textContent = p.icon;
  document.getElementById('planName').textContent = p.name;
  document.getElementById('planDetail').textContent = p.detail;

  // Email — show just the domain part if long
  const email = data.customer_email || "—";
  const shortEmail = email.length > 18 ? email.split('@')[0].substring(0,8)+'…@'+email.split('@')[1] : email;
  document.getElementById('detailEmail').textContent = shortEmail;

  // Trial end date
  if (data.trial_end) {
    const date = new Date(data.trial_end * 1000);
    document.getElementById('detailTrialEnd').textContent = date.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  } else {
    document.getElementById('detailTrialEnd').textContent = data.plan === 'free' ? 'Never' : 'Active';
  }
}

function showError(msg) {
  document.getElementById('stateLoading').style.display = 'none';
  document.getElementById('stateError').style.display = 'flex';
  document.getElementById('errorMsg').textContent = msg;
}

function goToOnboarding() {
  window.location.href = "onboarding.html";
}

// Run on load
confirmSession();
</script>
</body>
</html>
